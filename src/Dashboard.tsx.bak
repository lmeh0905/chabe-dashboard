const FUEL_LEVELS = ["1/4", "1/2", "3/4", "Plein"];
const FUEL_PCT: Record<string, number> = { "1/4": 25, "1/2": 50, "3/4": 75, "Plein": 100 };
const PROBLEM_CATS: { id: string; icon: string; label: string }[] = [
  { id: "body", icon: "🚗", label: "Carrosserie" }, { id: "mech", icon: "🔧", label: "Mécanique" },
  { id: "clean", icon: "🧹", label: "Propreté" }, { id: "fuel", icon: "⛽", label: "Carburant" },
