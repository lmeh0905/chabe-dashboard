  .g4{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
  .g3{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
  .g2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
